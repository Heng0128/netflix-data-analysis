```gitignore
# Compiled and binary files
*.pyc
*.pyo
*.pyd
__pycache__/
*.class
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build artifacts
dist/
build/
target/
*.egg-info/

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Coverage
.coverage
coverage/
htmlcov/

# Python specific
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
.installed.cfg
.pytest_cache/
.mypy_cache/

# System files
.DS_Store
Thumbs.db
```