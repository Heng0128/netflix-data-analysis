```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.exe
*.dll
*.so
*.class
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Build directories
dist/
build/
target/
*.log
*.tmp
*.swp
*.swo

# Editors
.vscode/
.idea/

# System files
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
.PyInstaller/
.pytest_cache/
.mypy_cache/

# Node.js specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*
node_modules/

# Java specific
*.class
*.jar
*.war
*.ear
*.nar
target/
.gradle/
!src/main/resources/static/node_modules/**/*

# Web specific
*.min.js
*.min.css
public/dist/
public/build/

# Compression archives
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```